# Configuration File for AssistBot
# Copy this file to config.env and fill in your actual values

# Required: Get from @botfather
BOT_TOKEN=your_bot_token_here

# Required: Get from https://my.telegram.org
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Sudo users have full access to the bot (comma-separated IDs)
SUDO_USERS_ID=123456789,987654321

# Log group for bot logs (must be a group where bot is admin)
LOG_GROUP_ID=-1001234567890

# Log group for global bans (must be a group where bot is admin)
GBAN_LOG_GROUP_ID=-1001234567890

# Chat for dumping messages (must be a group where bot is admin)
MESSAGE_DUMP_CHAT=-1001234567890

# Delay before kicking users who don't solve welcome captcha (seconds)
WELCOME_DELAY_KICK_SEC=600

# MongoDB connection URL (required for caching and database features)
MONGO_URL=mongodb://localhost:27017

# Enable/disable logging of bot mentions
LOG_MENTIONS=True

# RSS feed update delay (seconds)
RSS_DELAY=300

# Enable/disable PM permit system
PM_PERMIT=False

# Optional: DeepL API key for better translations (leave empty to use Google Translate)
DEEPL_API=

# Music Storage Options (required for music module to work)
# Set either MUSIC_GROUP_ID or MUSIC_CHANNEL_ID to a group/channel where bot is admin
# Music files will be uploaded here for caching
MUSIC_GROUP_ID=
MUSIC_CHANNEL_ID=
